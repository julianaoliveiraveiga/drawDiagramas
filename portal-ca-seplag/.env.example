# ============================================
# PORTAL CA SEPLAG - CONFIGURAÇÃO DE AMBIENTE
# ============================================

# Ambiente
VITE_APP_ENV=development

# Azure AD / MSAL
VITE_AZURE_CLIENT_ID=your-client-id
VITE_AZURE_TENANT_ID=your-tenant-id
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# Dataverse Web API
VITE_DATAVERSE_URL=https://your-org.crm.dynamics.com

# Custom APIs (C#)
VITE_CUSTOM_API_URL=https://your-api.azurewebsites.net

# Power Automate Flow URLs (AGD01.03)
# URLs dinâmicas por ambiente - não precisam alterar código
VITE_POWER_AUTOMATE_URL=https://prod-xx.westus.logic.azure.com
VITE_FLOW_DISPONIBILIDADE=https://prod-xx.westus.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke
VITE_FLOW_CRIAR_AGENDAMENTO=https://prod-xx.westus.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke
VITE_FLOW_CANCELAR_AGENDAMENTO=https://prod-xx.westus.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke
VITE_FLOW_CRIAR_OCORRENCIA=https://prod-xx.westus.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke
VITE_FLOW_BUSCAR_LOCALIZACOES=https://prod-xx.westus.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke
